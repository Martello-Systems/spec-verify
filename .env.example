# spec-verify: environment variables (copy to .env, fill in real values)
#
# The LLM judge reads ANTHROPIC_API_KEY from the environment. It is only needed
# for criteria WITHOUT a deterministic <!-- check: ... --> directive. With no
# key set, those criteria are reported UNVERIFIABLE (which does not fail the
# gate) and a warning is printed. Run with --no-judge to silence the warning.
#
# Never commit a real key.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
